{
  "name": "@tzam-st/tzam",
  "version": "0.10.0",
  "description": "Tzam - Tzam authentication client for Next.js - vigiar e proteger",
  "repository": "github:Tzam-St/tzam-next",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./proxy": {
      "types": "./dist/proxy.d.ts",
      "import": "./dist/proxy.mjs",
      "require": "./dist/proxy.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "auth",
    "tzam",
    "nextjs",
    "authentication",
    "tzam"
  ],
  "author": "carlosocarvalho",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  }
}